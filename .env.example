# Azure OpenAI — required for `--backend azure` in live/record modes.
# Replay mode reads cassettes/azure/ instead.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=YOUR_DEPLOYMENT_NAME
AZURE_OPENAI_API_VERSION=2024-10-21

# HuggingFace — required for `--backend gemma` first-time download. Accept
# the Gemma license on the HF UI first (it's gated):
#   https://huggingface.co/google/gemma-3n-E2B-it
HUGGINGFACE_TOKEN=

# LiteRT-LM bundle (same file gemmaclaw ships on-device). First run
# downloads ~2.6 GB into ./models/; subsequent runs are cached.
GEMMA_HF_REPO=litert-community/gemma-4-E2B-it-litert-lm
GEMMA_MODEL_FILE=gemma-4-E2B-it.litertlm
# Optional: skip the HF download and point at a local file
# (e.g. a copy from gemmaclaw/android/models/).
GEMMA_MODEL_PATH=
